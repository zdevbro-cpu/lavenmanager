# 에이멘에이 교재구매 시스템 백엔드 환경 변수 템플릿

# 1. Google Cloud SQL (PostgreSQL) 연결 문자열
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# 2. 백엔드 API 구동 포트
PORT=3001

# 3. 신청서 PDF가 저장될 구글 드라이브 폴더 ID
GOOGLE_DRIVE_FOLDER_ID=""

# 4. Gemini 2.0 Flash 멀티모달 OCR API 키
GEMINI_API_KEY=""

# 5. 구글 드라이브 OAuth2 (서비스 계정은 저장 쿼타 0이므로 사용 불가)
#    https://console.cloud.google.com/apis/credentials 에서 OAuth Web 클라이언트 발급
#    승인된 리디렉션 URI: http://localhost:3001/api/auth/google/callback
#    → /api/auth/google 접속 → 로그인 → REFRESH_TOKEN 발급받아 아래에 입력
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REFRESH_TOKEN=""
